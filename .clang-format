BasedOnStyle: LLVM
IndentWidth: 8
UseTab: Always
TabWidth: 8
ColumnLimit: 150
PointerAlignment: Left
AllowShortFunctionsOnASingleLine: None
BreakBeforeBraces: Custom
NamespaceIndentation: All
BraceWrapping:
        AfterClass: true
        AfterFunction: true
        AfterStruct: true
        AfterEnum: true
        AfterNamespace: true
        AfterControlStatement: Always
        BeforeElse: true
